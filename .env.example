# ============================================================
# ZeroLabs AI Publisher — Environment Variables Template
# ============================================================
# Copy this file to .env.local and fill in real values.
# Never commit .env.local or any file containing real secrets.
# See docs/environment-variables.md for the full reference.
# ============================================================

# ------------------------------------------------------------
# App identity — REQUIRED NOW
# ------------------------------------------------------------
NEXT_PUBLIC_APP_NAME=ZeroLabs AI Publisher
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ------------------------------------------------------------
# Supabase — database & authentication — REQUIRED NOW
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ------------------------------------------------------------
# OpenAI — AI content generation — REQUIRED NOW
# ------------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o

# ============================================================
# OPTIONAL — direct database tooling
# Used by migration scripts / ORM CLIs (Drizzle, Prisma).
# Not needed for runtime if using the Supabase client.
# ============================================================
# DATABASE_URL=postgresql://user:password@host:5432/dbname?pgbouncer=true
# DIRECT_URL=postgresql://user:password@host:5432/dbname

# ============================================================
# OPTIONAL — auth / session
# NEXT_PUBLIC_SITE_URL is used by Supabase for OAuth redirects.
# JWT_SECRET signs application-level session tokens if used.
# Generate JWT_SECRET with: openssl rand -base64 32
# ============================================================
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
# JWT_SECRET=replace_with_a_secure_random_secret_min_32_chars

# ============================================================
# FUTURE — Qdrant vector database
# Required only when semantic search / embedding features are active.
# ============================================================
# QDRANT_URL=https://your-qdrant-instance.qdrant.io
# QDRANT_API_KEY=your_qdrant_api_key
# QDRANT_COLLECTION=ai_publisher_default

# ============================================================
# FUTURE — Wasabi object storage (S3-compatible)
# Required only when asset upload / storage features are active.
# ============================================================
# WASABI_ACCESS_KEY_ID=your_wasabi_access_key_id
# WASABI_SECRET_ACCESS_KEY=your_wasabi_secret_access_key
# WASABI_BUCKET=your_wasabi_bucket
# WASABI_REGION=us-east-1
# WASABI_ENDPOINT=https://s3.wasabisys.com

# ============================================================
# FUTURE — billing (Stripe)
# Uncomment when billing features are enabled (ENABLE_BILLING=true).
# ============================================================
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================================
# FUTURE — email (Resend)
# Uncomment when transactional email features are enabled.
# ============================================================
# RESEND_API_KEY=re_...
# EMAIL_FROM=noreply@yourdomain.com

# ============================================================
# FUTURE — ZeroFlow platform services
# Uncomment when platform-level auth/billing/orchestration is active.
# ============================================================
# ZEROFLOW_API_URL=https://api.zeroflow.example
# ZEROFLOW_API_KEY=your_zeroflow_api_key

# ============================================================
# OPTIONAL â€” content scheduling execution
# CRON_SECRET can secure Vercel Cron or any external scheduler callback.
# SCHEDULER_BATCH_SIZE caps the number of due schedules claimed per run.
# ============================================================
# CRON_SECRET=replace_with_a_scheduler_bearer_token
# SCHEDULER_EXECUTION_TOKEN=replace_with_a_scheduler_bearer_token
# SCHEDULER_BATCH_SIZE=5

# ============================================================
# OPTIONAL - Meta / Instagram Graph publishing
# Required only when Instagram publishing integration is enabled.
# ============================================================
# META_APP_ID=your_meta_app_id
# META_APP_SECRET=your_meta_app_secret
# META_REDIRECT_URI=http://localhost:3000/api/social/accounts/callback/instagram
# INSTAGRAM_GRAPH_API_VERSION=v23.0

# ============================================================
# OPTIONAL - website deployment pipeline
# MVP-safe: mock is the default; Vercel supports dry-run or real deploy hooks.
# ============================================================
# PIPELINE_DEPLOYMENT_TARGET=mock
# PIPELINE_PREVIEW_BASE_URL=http://localhost:3000
# PIPELINE_PRODUCTION_BASE_URL=http://localhost:3000
# PIPELINE_MAX_ATTEMPTS=3
# PIPELINE_RETRY_BASE_DELAY_MS=100
# PIPELINE_VERCEL_API_URL=https://api.vercel.com
# PIPELINE_VERCEL_TOKEN=your_vercel_token
# PIPELINE_VERCEL_PROJECT_ID=your_vercel_project_id
# PIPELINE_VERCEL_TEAM_ID=your_vercel_team_id
# PIPELINE_VERCEL_DEPLOY_HOOK_PREVIEW_URL=https://api.vercel.com/v1/integrations/deploy/...
# PIPELINE_VERCEL_DEPLOY_HOOK_PRODUCTION_URL=https://api.vercel.com/v1/integrations/deploy/...
# PIPELINE_VERCEL_DEFAULT_DOMAIN=sites.example.com
# PIPELINE_VERCEL_ENABLE_REAL_DEPLOYMENTS=false
# PIPELINE_VERCEL_TIMEOUT_MS=15000

# ============================================================
# FUTURE — feature flags
# Set to "true" to enable the corresponding feature area.
# ============================================================
# ENABLE_ANALYTICS=false
# ENABLE_BILLING=false
# ENABLE_PUBLISHING=false
# ENABLE_PROJECT_CREATION=false
# ENABLE_ZEROFLOW_INTEGRATION=false

# ============================================================
# RUNTIME — Vercel-provided (do NOT set manually)
# Vercel automatically injects these at build and runtime.
# VERCEL_URL         — deployment URL without https://
# VERCEL_ENV         — "production", "preview", or "development"
# VERCEL_GIT_COMMIT_SHA — Git commit SHA for this deployment
# ============================================================
