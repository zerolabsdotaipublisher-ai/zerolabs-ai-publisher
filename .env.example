# App
NEXT_PUBLIC_APP_NAME=AI Publisher
NODE_ENV=development

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# OpenAI
OPENAI_API_KEY=your_openai_api_key

# Qdrant
QDRANT_URL=https://your-qdrant-instance.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key
QDRANT_COLLECTION=ai_publisher_default

# Wasabi (optional)
WASABI_ACCESS_KEY_ID=your_wasabi_access_key_id
WASABI_SECRET_ACCESS_KEY=your_wasabi_secret_access_key
WASABI_BUCKET=your_wasabi_bucket
WASABI_REGION=us-east-1

# ZeroFlow platform services (optional)
ZEROFLOW_API_URL=https://api.zeroflow.example
ZEROFLOW_API_KEY=your_zeroflow_api_key

# Auth / security
JWT_SECRET=replace_with_a_secure_random_secret

# Feature flags (optional)
ENABLE_ANALYTICS=false
ENABLE_BILLING=false
